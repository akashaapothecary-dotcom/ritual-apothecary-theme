<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Page Not Found</title>
    {{ 'ritual-apothecary.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="template-error theme-ritual-apothecary">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    {% section 'header' %}
    
    <main id="main-content" style="background: var(--color-dark-bg); padding: var(--spacing-3xl) var(--spacing-lg); text-align: center; min-height: 60vh; display: flex; align-items: center; justify-content: center;">
      <div style="max-width: 600px;">
        <h1 style="font-size: 3.5rem; color: var(--color-accent-gold); margin-bottom: var(--spacing-lg);">404</h1>
        <h2 style="font-size: 1.8rem; color: var(--color-candle-cream); margin-bottom: var(--spacing-lg);">Page Not Found</h2>
        <p style="color: var(--color-text-light); margin-bottom: var(--spacing-2xl);">The threshold you seek does not exist. Perhaps you've crossed the wrong doorway.</p>
        <a href="{{ routes.root_url }}" style="display: inline-block; background: var(--color-accent-gold); color: var(--color-dark-bg); padding: var(--spacing-md) var(--spacing-2xl); text-decoration: none; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">Return to the Apothecary</a>
      </div>
    </main>
    
    {% section 'footer' %}
  </body>
</html>