{% stylesheet %}
  .price {
    color: var(--color-accent-gold);
    font-weight: 600;
  }
  
  .badge {
    background: var(--color-dark-rose);
    color: var(--color-candle-cream);
    padding: var(--spacing-sm) var(--spacing-md);
    display: inline-block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
{% endstylesheet %}

{% if price %}
  <span class="price">{{ price | money }}</span>
{% endif %}