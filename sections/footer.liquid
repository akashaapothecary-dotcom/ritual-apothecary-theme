        </form>
        <div class="footer-social">
          <a href="#" aria-label="Instagram">📷</a>
          <a href="#" aria-label="Pinterest">📌</a>
          <a href="#" aria-label="TikTok">✨</a>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {{ "now" | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
      <div>
        <a href="{{ routes.pages_url }}/privacy" style="color: var(--color-text-muted); text-decoration: none; margin-right: 1.5rem;">Privacy</a>
        <a href="{{ routes.pages_url }}/terms" style="color: var(--color-text-muted); text-decoration: none;">Terms</a>
      </div>
    </div>
  </div>
</footer>