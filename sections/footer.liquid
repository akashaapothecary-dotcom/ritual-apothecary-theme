          <li><a href="{{ routes.collections_url }}/ritual-boxes">Ritual Boxes</a></li>
          <li><a href="{{ routes.collections_url }}/teas-elixirs">Teas & Elixirs</a></li>
          <li><a href="{{ routes.collections_url }}/herbal-body-care">Herbal Body Care</a></li>
          <li><a href="{{ routes.collections_url }}/womb-cycle">Womb & Cycle</a></li>
        </ul>
      </div>
      
      <!-- Support -->
      <div>
        <h3 class="footer-section-title">Support</h3>
        <ul class="footer-menu">
          <li><a href="{{ routes.pages_url }}/threshold-support">Private Support</a></li>
          <li><a href="{{ routes.pages_url }}/faq">FAQ</a></li>
          <li><a href="{{ routes.pages_url }}/shipping">Shipping & Returns</a></li>
          <li><a href="{{ routes.pages_url }}/care">Care Instructions</a></li>
        </ul>
      </div>
      
      <!-- Ritual -->
      <div>
        <h3 class="footer-section-title">Ritual</h3>
        <ul class="footer-menu">
          <li><a href="{{ routes.pages_url }}/about">About the Apothecary</a></li>
          <li><a href="{{ routes.blogs_url }}/journal">Journal</a></li>
          <li><a href="{{ routes.pages_url }}/philosophy">Philosophy</a></li>
          <li><a href="{{ routes.pages_url }}/contact">Contact</a></li>
        </ul>
      </div>
      
      <!-- Newsletter -->
      <div>
        <h3 class="footer-section-title">Letters from the Threshold</h3>
        <p style="font-size: 0.9rem; margin-bottom: 1rem; color: var(--color-text-light);">Seasonal rituals, grief notes, and product releases.</p>
        <form class="footer-newsletter-form">
          <input type="email" placeholder="Your email" required aria-label="Email address">
