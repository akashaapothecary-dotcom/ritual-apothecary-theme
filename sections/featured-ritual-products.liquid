{% stylesheet %}
  .featured-products-wrapper {
    background: var(--color-dark-bg);
    padding: var(--spacing-3xl) var(--spacing-lg);
  }
  
  .featured-products-container {
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .featured-products-title {
    font-size: 2.5rem;
    text-align: center;
    color: var(--color-accent-gold);
    margin-bottom: var(--spacing-3xl);
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-xl);
  }
  
  .product-card-ritual {
    background: var(--color-darker-bg);
    border: 2px solid var(--color-accent-gold);
    position: relative;
    overflow: hidden;
    transition: all var(--transition-base);
    display: flex;
    flex-direction: column;
  }
  
  .product-card-ritual:hover {
    border-color: var(--color-dark-rose);
    box-shadow: 0 0 30px rgba(184, 134, 11, 0.4), 0 0 30px rgba(139, 69, 69, 0.2);
    transform: translateY(-8px);
  }
  
  .product-card-image {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }
  
  .product-card-content {
    padding: var(--spacing-lg);
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  
  .product-card-title {
    font-size: 1.2rem;
    color: var(--color-candle-cream);
    margin-bottom: var(--spacing-md);
    font-weight: 600;
  }
  
  .product-card-price {
    font-size: 1.1rem;
    color: var(--color-accent-gold);
    margin-bottom: var(--spacing-md);
    font-weight: 600;
  }
  
  .product-card-description {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: var(--spacing-md);
    flex-grow: 1;
    line-height: 1.6;
  }
  
  .product-card-button {
    background: var(--color-accent-gold);
    color: var(--color-dark-bg);
    border: none;
    padding: var(--spacing-md);
    cursor: pointer;
    font-family: var(--font-serif-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all var(--transition-base);
    align-self: flex-start;
  }
  
  .product-card-button:hover {
    background: var(--color-accent-rose);
    transform: scale(1.05);
  }
  
  @media (max-width: 768px) {
    .featured-products-wrapper {
      padding: var(--spacing-2xl) var(--spacing-lg);
    }
    
    .featured-products-title {
      font-size: 1.8rem;
    }
    
    .products-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Ritual Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Offerings from the Apothecary"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured Ritual Products"
    }
  ]
}
{% endschema %}

<div class="featured-products-wrapper">
  <div class="featured-products-container">
    <h2 class="featured-products-title">{{ section.settings.title }}</h2>
    
    {% if section.settings.collection %}
      <div class="products-grid">
        {% for product in section.settings.collection.products limit: 4 %}
          <div class="product-card-ritual">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | img_url: '400x400' }}" alt="{{ product.title }}" class="product-card-image">
            {% endif %}
            
            <div class="product-card-content">
              <h3 class="product-card-title">{{ product.title }}</h3>
              <p class="product-card-price">{{ product.price | money }}</p>
              {% if product.description %}
                <p class="product-card-description">{{ product.description | strip_html | truncatewords: 20 }}</p>
              {% endif %}
              <a href="{{ product.url }}" class="product-card-button">View Offering</a>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>