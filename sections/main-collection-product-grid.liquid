{% stylesheet %}
  .collection-header {
    background: linear-gradient(135deg, var(--color-blackened-plum) 0%, var(--color-tobacco-brown) 100%);
    padding: var(--spacing-3xl) var(--spacing-lg);
    border-bottom: 2px solid var(--color-accent-gold);
    text-align: center;
  }
  
  .collection-title {
    font-size: 2.5rem;
    color: var(--color-accent-gold);
    margin-bottom: var(--spacing-md);
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  
  .collection-description {
    font-size: 1rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto;
  }
  
  .collection-wrapper {
    background: var(--color-dark-bg);
    padding: var(--spacing-3xl) var(--spacing-lg);
  }
  
  .collection-container {
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .collection-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-2xl);
    gap: var(--spacing-lg);
  }
  
  .collection-sort {
    display: flex;
    gap: var(--spacing-md);
    align-items: center;
  }
  
  .collection-sort select {
    background: var(--color-darker-bg);
    border: 1px solid var(--color-accent-gold);
    color: var(--color-text-light);
    padding: var(--spacing-sm);
    font-family: var(--font-serif-body);
  }
  
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--spacing-xl);
  }
  
  .product-card-ritual {
    background: var(--color-darker-bg);
    border: 2px solid var(--color-accent-gold);
    position: relative;
    overflow: hidden;
    transition: all var(--transition-base);
    display: flex;
    flex-direction: column;
  }
  
  .product-card-ritual:hover {
    border-color: var(--color-dark-rose);
    box-shadow: 0 0 30px rgba(184, 134, 11, 0.4), 0 0 30px rgba(139, 69, 69, 0.2);
    transform: translateY(-8px);
  }
  
  .product-card-image {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }
  
  .product-card-content {
    padding: var(--spacing-lg);
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  
  .product-card-title {
    font-size: 1.1rem;
    color: var(--color-candle-cream);
    margin-bottom: var(--spacing-md);
    font-weight: 600;
  }
  
  .product-card-price {
    font-size: 1.05rem;
    color: var(--color-accent-gold);
    margin-bottom: var(--spacing-lg);
    font-weight: 600;
  }
  
  .product-card-link {
    background: var(--color-accent-gold);
    color: var(--color-dark-bg);
    padding: var(--spacing-md);
    text-align: center;
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all var(--transition-base);
  }
  
  .product-card-link:hover {
    background: var(--color-accent-rose);
  }
  
  @media (max-width: 768px) {
    .collection-wrapper {
      padding: var(--spacing-2xl) var(--spacing-lg);
    }
    
    .collection-title {
      font-size: 1.8rem;
    }
    
    .collection-controls {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .products-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

<div class="collection-header">
  <h1 class="collection-title">{{ collection.title }}</h1>
  {% if collection.description %}
    <p class="collection-description">{{ collection.description | strip_html }}</p>
  {% endif %}
</div>

<div class="collection-wrapper">
  <div class="collection-container">
    <div class="collection-controls">
      <div class="collection-sort">
        <label for="sort-by" style="color: var(--color-text-light);">Sort by:</label>
        <select id="sort-by" onchange="if(this.value) window.location.href=this.value;">
          <option selected>Featured</option>
          <option value="{{ collection.url }}?sort_by=best-selling">Best Selling</option>
          <option value="{{ collection.url }}?sort_by=title-ascending">Title (A-Z)</option>
          <option value="{{ collection.url }}?sort_by=price-ascending">Price (Low to High)</option>
          <option value="{{ collection.url }}?sort_by=price-descending">Price (High to Low)</option>
        </select>
      </div>
    </div>
    
    <div class="products-grid">
      {% for product in collection.products %}
        <div class="product-card-ritual">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | img_url: '400x400' }}" alt="{{ product.title }}" class="product-card-image">
          {% endif %}
          
          <div class="product-card-content">
            <h3 class="product-card-title">{{ product.title }}</h3>
            <div class="product-card-price">
              {% if product.price_varies %}
                From {{ product.price_min | money }}
              {% else %}
                {{ product.price | money }}
              {% endif %}
            </div>
            <a href="{{ product.url }}" class="product-card-link">View Offering</a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>