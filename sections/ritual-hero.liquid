{% stylesheet %}
  .ritual-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background-color: var(--color-dark-bg);
  }
  
  .ritual-hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    z-index: 1;
  }
  
  .ritual-hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(26, 26, 26, var(--overlay-opacity, 0.7));
    z-index: 2;
  }
  
  .ritual-hero-content {
    position: relative;
    z-index: 3;
    max-width: 800px;
    padding: var(--spacing-xl);
    animation: fadeInUp 1s ease 0.3s both;
  }
  
  .ritual-hero-heading {
    font-size: 3.5rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-accent-gold);
    margin-bottom: var(--spacing-lg);
    text-transform: uppercase;
    letter-spacing: 2px;
    text-shadow: 0 4px 15px rgba(0, 0, 0, 0.8);
  }
  
  .ritual-hero-subheading {
    font-size: 1.3rem;
    color: var(--color-candle-cream);
    margin-bottom: var(--spacing-2xl);
    line-height: 1.8;
    font-weight: 300;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .ritual-hero-buttons {
    display: flex;
    gap: var(--spacing-lg);
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeInUp 1s ease 0.6s both;
  }
  
  .ritual-hero-button {
    padding: var(--spacing-md) var(--spacing-2xl);
    font-size: 0.95rem;
    letter-spacing: 1px;
    transition: all var(--transition-base);
  }
  
  .ritual-hero-button.primary {
    background-color: var(--color-accent-gold);
    color: var(--color-dark-bg);
    border: none;
  }
  
  .ritual-hero-button.primary:hover {
    background-color: var(--color-accent-rose);
    box-shadow: 0 0 30px rgba(184, 134, 11, 0.6);
    transform: translateY(-3px);
  }
  
  .ritual-hero-button.secondary {
    background-color: transparent;
    color: var(--color-accent-gold);
    border: 2px solid var(--color-accent-gold);
  }
  
  .ritual-hero-button.secondary:hover {
    background-color: var(--color-accent-gold);
    color: var(--color-dark-bg);
    box-shadow: 0 0 30px rgba(184, 134, 11, 0.6);
    transform: translateY(-3px);
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @media (max-width: 768px) {
    .ritual-hero {
      height: 60vh;
    }
    
    .ritual-hero-heading {
      font-size: 2.2rem;
    }
    
    .ritual-hero-subheading {
      font-size: 1rem;
    }
    
    .ritual-hero-buttons {
      flex-direction: column;
      gap: var(--spacing-md);
    }
    
    .ritual-hero-button {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Ritual Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ritual Apothecary for the Thresholds of Becoming"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Handcrafted herbal offerings, ritual boxes, grief tending tools, teas, oils, balms, and ceremonial objects for those moving through loss, rebirth, survival, softness, and spiritual transformation."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.7
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary Button Label",
      "default": "Enter the Apothecary"
    },
    {
      "type": "url",
      "id": "primary_button_url",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary Button Label",
      "default": "Find Your Threshold"
    },
    {
      "type": "url",
      "id": "secondary_button_url",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Ritual Hero"
    }
  ]
}
{% endschema %}

<style>
  .ritual-hero {
    --overlay-opacity: {{ section.settings.overlay_opacity }};
  }
</style>

<section class="ritual-hero" style="{% if section.settings.background_image %}background-image: url('{{ section.settings.background_image | img_url: '1920x1080' }}');{% endif %}">
  {% if section.settings.background_image %}
    <div class="ritual-hero-background" style="background-image: url('{{ section.settings.background_image | img_url: '1920x1080' }}');"></div>
  {% endif %}
  <div class="ritual-hero-overlay"></div>
  
  <div class="ritual-hero-content">
    <h1 class="ritual-hero-heading">{{ section.settings.heading }}</h1>
    <p class="ritual-hero-subheading">{{ section.settings.subheading }}</p>
    
    <div class="ritual-hero-buttons">
      {% if section.settings.primary_button_label %}
        <a href="{{ section.settings.primary_button_url | default: '#' }}" class="ritual-hero-button primary">{{ section.settings.primary_button_label }}</a>
      {% endif %}
      {% if section.settings.secondary_button_label %}
        <a href="{{ section.settings.secondary_button_url | default: '#' }}" class="ritual-hero-button secondary">{{ section.settings.secondary_button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>