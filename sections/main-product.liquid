{% stylesheet %}
  .main-product-wrapper {
    background: var(--color-dark-bg);
    padding: var(--spacing-3xl) var(--spacing-lg);
  }
  
  .main-product-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-3xl);
  }
  
  .product-media-wrapper {
    position: relative;
  }
  
  .product-main-image {
    width: 100%;
    border: 2px solid var(--color-accent-gold);
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }
  
  .product-info-wrapper {
    display: flex;
    flex-direction: column;
  }
  
  .product-title {
    font-size: 2rem;
    color: var(--color-candle-cream);
    margin-bottom: var(--spacing-md);
    font-weight: 600;
  }
  
  .product-price {
    font-size: 1.3rem;
    color: var(--color-accent-gold);
    margin-bottom: var(--spacing-lg);
    font-weight: 600;
  }
  
  .product-description {
    font-size: 1rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: var(--spacing-lg);
  }
  
  .product-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-2xl);
  }
  
  .variant-picker,
  .quantity-picker {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  
  .variant-label,
  .quantity-label {
    font-weight: 600;
    color: var(--color-candle-cream);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  
  .variant-options,
  .quantity-input {
    display: flex;
    gap: var(--spacing-md);
  }
  
  .variant-option {
    padding: var(--spacing-md);
    border: 2px solid var(--color-accent-gold);
    background: transparent;
    color: var(--color-text-light);
    cursor: pointer;
    transition: all var(--transition-base);
  }
  
  .variant-option:hover {
    background: var(--color-accent-gold);
    color: var(--color-dark-bg);
  }
  
  .quantity-input input {
    width: 80px;
    background: var(--color-darker-bg);
    border: 1px solid var(--color-accent-gold);
    color: var(--color-text-light);
    padding: var(--spacing-md);
    text-align: center;
  }
  
  .add-to-cart-button {
    background: var(--color-accent-gold);
    color: var(--color-dark-bg);
    padding: var(--spacing-lg) var(--spacing-2xl);
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: none;
    cursor: pointer;
    transition: all var(--transition-base);
  }
  
  .add-to-cart-button:hover {
    background: var(--color-accent-rose);
    transform: scale(1.02);
  }
  
  .product-accordion {
    border-top: 1px solid var(--color-accent-gold);
    margin-top: var(--spacing-2xl);
  }
  
  .accordion-item {
    border-bottom: 1px solid var(--color-accent-gold);
  }
  
  .accordion-trigger {
    background: transparent;
    border: none;
    width: 100%;
    padding: var(--spacing-lg);
    color: var(--color-candle-cream);
    font-size: 1rem;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all var(--transition-base);
  }
  
  .accordion-trigger:hover {
    color: var(--color-accent-gold);
  }
  
  .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    padding: 0 var(--spacing-lg);
  }
  
  .accordion-content-inner {
    padding: var(--spacing-lg) 0;
    color: var(--color-text-light);
    line-height: 1.8;
  }
  
  @media (max-width: 768px) {
    .main-product-container {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }
{% endstylesheet %}

<div class="main-product-wrapper">
  <div class="main-product-container">
    <!-- Product Media -->
    <div class="product-media-wrapper">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '600x600' }}" alt="{{ product.title }}" class="product-main-image">
      {% endif %}
    </div>
    
    <!-- Product Info -->
    <div class="product-info-wrapper">
      <h1 class="product-title">{{ product.title }}</h1>
      
      <div class="product-price">
        {% if product.price_varies %}
          From {{ product.price_min | money }}
        {% else %}
          {{ product.price | money }}
        {% endif %}
      </div>
      
      {% if product.description %}
        <div class="product-description">{{ product.description | strip_html }}</div>
      {% endif %}
      
      <form class="product-form" method="post" action="{{ routes.cart_add_url }}">
        {% if product.variants.size > 1 %}
          <div class="variant-picker">
            <label for="variant-select" class="variant-label">Select Option</label>
            <select name="id" id="variant-select">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}">{{ variant.title }}</option>
              {% endfor %}
            </select>
          </div>
        {% else %}
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        {% endif %}
        
        <div class="quantity-picker">
          <label for="quantity" class="quantity-label">Quantity</label>
          <div class="quantity-input">
            <button type="button" onclick="this.nextElementSibling.value = Math.max(1, parseInt(this.nextElementSibling.value) - 1)">−</button>
            <input type="number" name="quantity" id="quantity" value="1" min="1">
            <button type="button" onclick="this.previousElementSibling.value = parseInt(this.previousElementSibling.value) + 1">+</button>
          </div>
        </div>
        
        <button type="submit" class="add-to-cart-button">Add to Cart</button>
      </form>
      
      <!-- Product Details Accordion -->
      <div class="product-accordion">
        <div class="accordion-item">
          <button class="accordion-trigger" data-accordion-trigger aria-expanded="false">
            <span>What This Offering Supports</span>
            <span>+</span>
          </button>
          <div class="accordion-content" aria-hidden="true">
            <div class="accordion-content-inner">
              {% if product.metafields.custom.supports %}
                {{ product.metafields.custom.supports }}
              {% else %}
                This offering is designed to support your journey through ritual, transformation, and threshold crossing.
              {% endif %}
            </div>
          </div>
        </div>
        
        <div class="accordion-item">
          <button class="accordion-trigger" data-accordion-trigger aria-expanded="false">
            <span>How to Use Ritually</span>
            <span>+</span>
          </button>
          <div class="accordion-content" aria-hidden="true">
            <div class="accordion-content-inner">
              {% if product.metafields.custom.ritual_use %}
                {{ product.metafields.custom.ritual_use }}
              {% else %}
                Use this offering as part of your personal ritual practice. Honor it, engage with it sensually, and let it guide your intention.
              {% endif %}
            </div>
          </div>
        </div>
        
        <div class="accordion-item">
          <button class="accordion-trigger" data-accordion-trigger aria-expanded="false">
            <span>Ingredients & Materials</span>
            <span>+</span>
          </button>
          <div class="accordion-content" aria-hidden="true">
            <div class="accordion-content-inner">
              {% if product.metafields.custom.ingredients %}
                {{ product.metafields.custom.ingredients }}
              {% else %}
                Crafted with intention from high-quality botanical and natural materials.
              {% endif %}
            </div>
          </div>
        </div>
        
        <div class="accordion-item">
          <button class="accordion-trigger" data-accordion-trigger aria-expanded="false">
            <span>Safety & Care Notes</span>
            <span>+</span>
          </button>
          <div class="accordion-content" aria-hidden="true">
            <div class="accordion-content-inner">
              {% if product.metafields.custom.safety_notes %}
                {{ product.metafields.custom.safety_notes }}
              {% else %}
                For external use. Not intended to diagnose, treat, cure, or prevent any disease. Patch test before use.
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>