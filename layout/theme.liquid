<!DOCTYPE html>
<html lang="{{ shop.locale }}">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#1a1a1a">
    
    <title>{{ page_title }}</title>
    <meta name="description" content="{{ page_description | escape }}">
    
    <link rel="canonical" href="{{ canonical_url }}">
    
    <!-- Theme CSS -->
    {{ 'ritual-apothecary.css' | asset_url | stylesheet_tag }}
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Playfair+Display:wght@400;600;700;800&family=EB+Garamond:wght@400;500;600&display=swap" rel="stylesheet">
    
    {% if settings.favicon != blank %}
      <link rel="icon" type="image/png" href="{{ settings.favicon | img_url: '32x32' }}">
    {% endif %}
    
    {{ content_for_header }}
  </head>
  
  <body class="template-{{ template | replace: '.', '-' }} theme-ritual-apothecary">
    
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    {% section 'header' %}
    
    <main id="main-content" role="main">
      {{ content_for_layout }}
    </main>
    
    {% section 'footer' %}
    
    <script src="{{ 'ritual-apothecary.js' | asset_url }}" defer></script>
  </body>
</html>